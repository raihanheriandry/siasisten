name: Cek Lowongan SIAsisten

on:
  schedule:
    - cron: "*/5 * * * *"   # setiap 5 menit
  workflow_dispatch:

jobs:
  run:
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v3

    - name: Setup Python
      uses: actions/setup-python@v4
      with:
        python-version: "3.10"

    - name: Install dependencies
      run: pip install requests beautifulsoup4

    - name: Run checker
      env:
        SIASISTEN_USER: ${{ secrets.SIASISTEN_USER }}
        SIASISTEN_PASS: ${{ secrets.SIASISTEN_PASS }}
        DISCORD_WEBHOOK: ${{ secrets.DISCORD_WEBHOOK }}
      run: python main.py

    - name: Save last results
      uses: actions/upload-artifact@v3
      with:
        name: last
        path: last.json
